# ─────────────────────────────────────────────────────────────────────────────
# AIKAGAN — Environment Variables (template)
# Copy to .env.local and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Paddle Billing (replaces Stripe) ────────────────────────────────────────
# Paddle is the Merchant of Record — handles global tax/VAT compliance.
# Works from Turkey (Stripe does not support Turkish merchants).
# Get these from https://vendors.paddle.com → Developer Tools
#
# Server-side API key (starts with pdl_...)
PADDLE_API_KEY=
# Client-side token for Paddle.js (starts with pct_...)
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
# Webhook signing secret (starts with psk_...)
# Create endpoint: Paddle Dashboard → Developer Tools → Webhooks → Add
#   Endpoint URL: https://aikagan.com/api/webhooks/paddle
#   Events:       transaction.completed
PADDLE_WEBHOOK_SECRET=

# ── Download Token Security ────────────────────────────────────────────────
# Random 32+ hex chars for HMAC-signed download tokens
# Generate: openssl rand -hex 32
DOWNLOAD_TOKEN_SECRET=

# ── Site URL ───────────────────────────────────────────────────────────────
# Used by Paddle success redirect
NEXT_PUBLIC_SITE_URL=https://aikagan.com

# ── Contact form (Formspree) ───────────────────────────────────────────────
# Get your free ID at https://formspree.io → New Form → copy the 8-char ID
NEXT_PUBLIC_FORMSPREE_ID=

# ── Analytics (leave blank to disable) ────────────────────────────────────
# Google Analytics 4 Measurement ID  (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Meta Pixel ID  (e.g. 1234567890)
NEXT_PUBLIC_META_PIXEL_ID=

# ── AutonomaX Revenue Ops backend (Cloud Run) ─────────────────────────────
NEXT_PUBLIC_AUTONOMAX_API_URL=https://autonomax-revenue-ops-71658389068.us-central1.run.app
# Internal auth key for server-to-server proxy calls
AUTONOMAX_API_KEY=

# ── Vercel KV (optional — used for download token persistence) ────────────
# Set these if using Vercel KV; omit to fall back to HMAC-only validation
KV_REST_API_URL=
KV_REST_API_TOKEN=

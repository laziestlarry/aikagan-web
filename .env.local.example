# ─────────────────────────────────────────────────────────────────────────────
# AIKAGAN — Environment Variables (template)
# Copy to .env.local and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Paddle Billing (LIVE) ──────────────────────────────────────────────────
# Paddle is the Merchant of Record — replaces Stripe (which doesn't support
# Turkish-registered merchants). Get these from paddle.com → Developer Tools.
# Paddle API key (starts with pdl_...):
PADDLE_API_KEY=
# Paddle client-side token for Paddle.js (starts with pct_...):
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
# Paddle webhook signing secret (starts with psk_...):
# Configure in Paddle Dashboard → Developer Tools → Webhooks
#   Endpoint URL: https://aikagan.com/api/webhooks/paddle
#   Events:       transaction.completed
PADDLE_WEBHOOK_SECRET=

# ── Download Token Security ────────────────────────────────────────────────
# Used by download-token.ts for HMAC-signed download links (48h TTL).
# Generate a new one: openssl rand -hex 32
DOWNLOAD_TOKEN_SECRET=

# ── Site URL (used by Paddle success redirect) ─────────────────────────────
NEXT_PUBLIC_SITE_URL=https://aikagan.com
# Use an already-approved Paddle checkout domain when the public content
# domain is still pending approval, e.g. https://app.aikagan.com or
# https://propulse-autonomax.web.app.
NEXT_PUBLIC_PADDLE_CHECKOUT_BASE_URL=

# ── Contact form (Formspree) ──────────────────────────────────────────────
NEXT_PUBLIC_FORMSPREE_ID=


# ── Analytics ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
META_CAPI_SHARED_SECRET=
META_GRAPH_VERSION=v22.0

# ── AutonomaX Revenue Ops backend (Fly.io) ───────────────────────────────
NEXT_PUBLIC_AUTONOMAX_API_URL=
AUTONOMAX_API_KEY=

# ── ProPulse FastAPI backend (same Fly.io backend) ───────────────────────
# Both proxies now point to the same merged backend on Fly.io
NEXT_PUBLIC_FASTAPI_URL=
# Proxy timeouts (ms) — increase if backend has cold-start latency
REVENUE_OPS_PROXY_TIMEOUT=10000
FASTAPI_PROXY_TIMEOUT=15000

# ── Vercel KV (Pro) or Upstash Redis REST (Hobby / free tier) ─────────────
# For Upstash: https://upstash.com → Create Redis Database → REST credentials
# For Vercel KV: Vercel → Storage → KV → connect to project
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Security secrets (generate: openssl rand -hex 32) ──────────────────────
# Used by /admin/income and /api/admin/affiliates
ADMIN_SECRET=
# Used by Vercel Cron (set this in Vercel project env so cron can call back)
CRON_SECRET=
# Internal CAPI proxy shared secret (optional — for future server-to-server auth)
AIKAGAN_CAPI_SHARED_SECRET=

# ── LemonSqueezy checkout URL overrides (optional — hardcoded defaults exist in lib/products.ts)
NEXT_PUBLIC_LS_STARTER_URL=
NEXT_PUBLIC_LS_PRO_URL=
NEXT_PUBLIC_LS_COMMANDER_URL=

# ── Analytics (leave blank to disable)
# Google Analytics 4 Measurement ID  (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Meta Pixel ID  (e.g. 1234567890)
NEXT_PUBLIC_META_PIXEL_ID=

# ── LemonSqueezy webhook & download security
# From LemonSqueezy → Store Settings → Webhooks → Signing Secret
LEMONSQUEEZY_WEBHOOK_SECRET=

# Random 32+ char secret used to sign download tokens (generate: openssl rand -hex 32)
DOWNLOAD_TOKEN_SECRET=

# ── AutonomaX Revenue Ops backend (Cloud Run)
NEXT_PUBLIC_AUTONOMAX_API_URL=https://autonomax-revenue-ops-71658389068.us-central1.run.app
# Internal auth key for server-to-server proxy calls
AUTONOMAX_API_KEY=

# ── Vercel KV (optional — used for download token persistence)
# Set these if using Vercel KV; omit to fall back to HMAC-only validation
KV_REST_API_URL=
KV_REST_API_TOKEN=

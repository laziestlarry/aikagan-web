# ─────────────────────────────────────────────────────────────────────────────
# AIKAGAN ProfitOS — production environment template
# Copy to .env.local for local development. Never commit real secret values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://aikagan.com

# ── Paddle Billing ────────────────────────────────────────────────────────────
# Paddle is approved only on app.aikagan.com and propulse-autonomax.web.app.
# Do not force this rail on aikagan.com unless Paddle approves that domain.
PADDLE_API_KEY=
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
PADDLE_WEBHOOK_SECRET=
PADDLE_CHECKOUT_DISABLED=true
NEXT_PUBLIC_PADDLE_CHECKOUT_BASE_URL=https://app.aikagan.com

# ── Gumroad ───────────────────────────────────────────────────────────────────
# Main storefront hosted rail for Starter / Pro / Commander.
# Configure Ping URL:
# https://aikagan.com/api/webhooks/gumroad?token=<GUMROAD_WEBHOOK_TOKEN>
GUMROAD_WEBHOOK_TOKEN=

# ── Shopier ───────────────────────────────────────────────────────────────────
# Either the standard or AUTONOMAX-prefixed names may be used.
SHOPIER_PAT=
SHOPIER_OSB_USERNAME=
SHOPIER_OSB_PASSWORD=
AUTONOMAX_SHOPIER_PAT=
AUTONOMAX_SHOPIER_OSB_USERNAME=
AUTONOMAX_SHOPIER_OSB_KEY=

# ── Lemon Squeezy (keep blank unless merchant store is approved) ─────────────
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
# Example: LEMONSQUEEZY_VARIANT_MASTERCLASS_STARTER=

# ── Fulfillment ───────────────────────────────────────────────────────────────
# MAKE_WEBHOOK_URL is retained as a legacy alias. Prefer the explicit names.
MAKE_WEBHOOK_URL=
MAKE_PURCHASE_WEBHOOK_URL=
MAKE_CUSTOMER_SERVICE_WEBHOOK_URL=
MAKE_LEAD_MAGNET_WEBHOOK_URL=
MAKE_OMNICHANNEL_WEBHOOK_URL=

# ── Download-token security ──────────────────────────────────────────────────
# Generate: openssl rand -hex 32
DOWNLOAD_TOKEN_SECRET=

# ── Durable evidence ledger / queue ──────────────────────────────────────────
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Contact form ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_FORMSPREE_ID=

# ── Analytics and Meta CAPI ──────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
META_GRAPH_VERSION=v22.0

# ── Optional AutonomaX backends ──────────────────────────────────────────────
NEXT_PUBLIC_AUTONOMAX_API_URL=
AUTONOMAX_API_KEY=
NEXT_PUBLIC_FASTAPI_URL=
REVENUE_OPS_PROXY_TIMEOUT=10000
FASTAPI_PROXY_TIMEOUT=15000

# ── Operator security ─────────────────────────────────────────────────────────
ADMIN_SECRET=
CRON_SECRET=
AIKAGAN_CAPI_SHARED_SECRET=
